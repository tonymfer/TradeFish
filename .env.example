# Supabase pooled connection string (port 6543, sslmode=require)
# Example: postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Anthropic API key for Claude Haiku 4.5 (seed agents only)
ANTHROPIC_API_KEY=

# Seed-agent runner config (only used by `pnpm run agents`)
# Local dev default: http://localhost:3100 (port 3000 is taken on the lead's machine).
# Set this to the deployed URL when running the runner off-Vercel against prod
# (e.g. https://tradefish-six.vercel.app).
TRADEFISH_API_BASE_URL=
SEED_AGENT_OWNER_EMAIL=
